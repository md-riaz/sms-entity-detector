# SMS Identifier – environment configuration
# Copy this file to .env and adjust values as needed.

# -------------------------------------------------------------------------
# Data paths (defaults are relative to the app's working directory)
# -------------------------------------------------------------------------
DATA_DIR=./data
DB_PATH=./data/sqlite/sms_identifier.db
QUEUE_DIR=./data/queue
LOG_DIR=./data/logs

# -------------------------------------------------------------------------
# API server
# -------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8117

# -------------------------------------------------------------------------
# Worker
# -------------------------------------------------------------------------
WORKER_BATCH_SIZE=50
WORKER_SLEEP_SECONDS=2.0

# -------------------------------------------------------------------------
# ML model
# -------------------------------------------------------------------------
NER_MODEL_NAME=Davlan/xlm-roberta-base-ner-hrl

# Set to "false" to disable ML model (rule-only mode, useful for local dev)
MODEL_ENABLED=true

# Minimum NER confidence to consider an entity as a sender signal
ORG_SCORE_THRESHOLD=0.80

# Minimum character length of an entity to count as a sender identity
MIN_ENTITY_LENGTH=3
